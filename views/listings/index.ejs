<style>
    #filters {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
}

.filter {
  text-align: center;
  margin-right: 2rem;
  margin-top: 2rem;
    margin-bottom: 2rem;
  opacity: 0.7;
}
.filter:hover {
    opacity: 1;
    cursor: pointer;
}

.filter p {
  margin-bottom: 0;
}

  .tax-info {
  display: none;
}

.tax-toggle {
  border: 1px solid black;
  border-radius: 1rem;
  padding: 0.75rem 1rem;
  margin-left: auto;
  width: fit-content;
  display: flex;
  align-items: center;
}

.tax-toggle .tax-toggle-inner {
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

.tax-toggle .form-check-label {
  margin-bottom: 0;
}

.tax-toggle .form-check-input {
  margin: 0;
  flex-shrink: 0;
}

</style>


<div id="filters">
  <div class="filter">
    <div><i class="fa-solid fa-fire"></i></div>
    <p>Trending</p>
  </div>

  <div class="filter">
    <div><i class="fa-solid fa-bed"></i></div>
    <p>Rooms</p>
  </div>

  <div class="filter">
    <div><i class="fa-solid fa-mountain-city"></i></div>
    <p>Iconic Cities</p>
  </div>

  <div class="filter">
    <div><i class="fa-solid fa-mountain"></i></div>
    <p>Mountains</p>
  </div>

  <div class="filter">
    <div><i class="fa-solid fa-ship"></i></div>
    <p>Ship</p>
  </div>

  <div class="filter">
    <div><i class="fa-solid fa-person-swimming"></i></div>
    <p>amazing pools</p>
  </div>

  <div class="filter">
    <div><i class="fa-solid fa-campground"></i></div>
    <p>Camping</p>
  </div>


<div class="filter">
    <div><i class="fa-solid fa-snowflake"></i></div>
    <p>Arctic</p>
  </div>

  <div class="filter">
    <div><i class="fa-brands fa-behance"></i></div>
    <p> Dance</p>
  </div>

  <div class="filter">
    <div><i class="fa-brands fa-pagelines"></i></div>
    <p>leaf</p>
  </div>



  <div class="tax-toggle">

<div class="tax-toggle-inner form-switch">
  <label class="form-check-label" for="switchCheckDefault">Display Total After Taxes</label>
  <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
</div>

  </div>

</div>






    <div class="row g-4">
    <%  for(let listing of allListings){ %>
        <div class="col-xl-4 col-md-6 col-12">
  <a href="/listings/<%= listing._id %>" class="listing-links">
  <article class="card listing-card listing-card-modern h-100">
   <div class="listing-image-wrap">
    <img src="<%= listing.image?.url || listing.image %>" class="card-img-top listing-index-img" alt="listing_image">
    <div class="listing-card-overlay"></div>
 </div>

  <div class="card-body listing-card-body">
  <div class="listing-card-row">
   <h3 class="listing-card-title"><%= listing.title %></h3>
    <span class="listing-price-pill">&#8377; <%= listing.price.toLocaleString("en-IN") %>
       <i class="tax-info">&nbsp;&nbsp;+18% GST</i></span>
   </div>
      <p class="listing-location"><%= listing.location %>, <%= listing.country %></p>
     <p class="listing-rate">per night</p>
    </div>
     </article>
    </a>
        </div>
     <% }%> 
    </div>
</section>


<script>
  const taxSwitch = document.getElementById("switchCheckDefault");

  if (taxSwitch) {
    taxSwitch.addEventListener("change", () => {
      let taxInfo = document.getElementsByClassName("tax-info");

for (info of taxInfo) {
  if (info.style.display != "inline") {
    info.style.display = "inline";
  } else {
    info.style.display = "none";
  }
}
    });
  }
</script>
