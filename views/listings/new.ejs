<% layout("/layouts/boilerplate") %>
<div class="row mt-3">
 <!-- offset se hi mera form centre mae aa gya jab input field ka size is 8 cols -->
<div class="col-8 offset-2">
    <br>
    <br>
    <h2> ENTER NEW LISTING</h2>
    <form method="post" action="/listings"  novalidate class="needs-validation"   enctype="multipart/form-data"                          >
        <div class="mb-3">
        <label for="title" class="form-label">Title</label>
        <input type="text" name="listing[title]"  class="form-control" placeholder="Add a title" required>
        <div class="invalid-feedback"> Price should be more than 0</div>
        <div class="valid-feedback"> Title looks good</div>
        </div>

         <div class="mb-3">
        <label for="description" class="form-label">description</label>
       <input type="text" name="listing[description]" class="form-control" required>
       <div class="invalid-feedback"> Price should be more than 0</div>
        </div>

          <!-- <div class="mb-3">
        <label for="image" class="form-label">image</label>
       <input type="text" name="listing[image]"  class="form-control" placeholder="enter image URL/Link">
        </div> -->
       <div class="mb-3">
        <label for="image" class="form-label">Upload Image</label>
       <input type="file" name="listing[image]"  class="form-control" >
        </div>


    
<div class="row">
 <div class="mb-3 col-md-4">
        <label for="price" class="form-label">price</label>
       <input type="number" name="listing[price]" class="form-control" placeholder="1200" required>
       <div class="invalid-feedback"> Price should be more than 0</div>
        </div>
          <div class="mb-3 col-md-8">
        <label for="location" class="form-label">location</label>
       <input type="text" name="listing[location]" class="form-control" placeholder="Haryana" required>
       <div class="invalid-feedback"> Price should be more than 0</div>
        </div>
</div>
         <div class="mb-3">
        <label for="country" class="form-label">country</label>
       <input type="text" name="listing[country]"   class="form-control" placeholder="India" required>
       <div class="invalid-feedback"> Price should be more than 0</div>
        </div>
        <br>
        <br>
      
        <button class="btn btn-dark add-btn  mt-3">sumbit</button>
        <br>
        <br>
    </form>
</div>
</div>